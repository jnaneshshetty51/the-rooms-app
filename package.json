{
  "name": "the-rooms",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "dev:web": "turbo dev --filter=@the-rooms/web",
    "dev:guest": "turbo dev --filter=@the-rooms/guest-portal",
    "dev:front-office": "turbo dev --filter=@the-rooms/front-office",
    "dev:admin": "turbo dev --filter=@the-rooms/admin",
    "dev:super-admin": "turbo dev --filter=@the-rooms/super-admin",
    "build": "turbo build",
    "build:web": "turbo build --filter=@the-rooms/web",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "db:push": "turbo db:push --filter=@the-rooms/db",
    "db:migrate": "turbo db:migrate --filter=@the-rooms/db",
    "db:seed": "turbo db:seed --filter=@the-rooms/db",
    "docker:up": "docker compose -f docker-compose.yml up -d",
    "docker:down": "docker compose -f docker-compose.yml down",
    "docker:logs": "docker compose -f docker-compose.yml logs -f"
  },
  "devDependencies": {
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "turbo": "^2.4.4",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "packageManager": "pnpm@11.4.0"
}
